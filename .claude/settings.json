{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"C:/Program Files/PowerShell/7/pwsh.exe\" -NoProfile -ExecutionPolicy Bypass -File \"$CLAUDE_PROJECT_DIR/.claude/hooks/plan-gate-prompt.ps1\""
          },
          {
            "type": "command",
            "command": "\"C:/Program Files/PowerShell/7/pwsh.exe\" -NoProfile -ExecutionPolicy Bypass -File \"$CLAUDE_PROJECT_DIR/.claude/hooks/subagent-router.ps1\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"C:/Program Files/PowerShell/7/pwsh.exe\" -NoProfile -ExecutionPolicy Bypass -File \"$CLAUDE_PROJECT_DIR/.claude/hooks/plan-gate-pretool.ps1\""
          }
        ]
      }
    ]
  }
}
