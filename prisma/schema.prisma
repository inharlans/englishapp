generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Word {
  id           Int           @id @default(autoincrement())
  en           String        @unique
  ko           String
  createdAt    DateTime      @default(now())
  progresses   Progress[]
  resultStates ResultState[]
  quizProgress QuizProgress[]
}

model Progress {
  userId                 Int
  wordId                 Int
  correctStreak          Int       @default(0)
  nextReviewAt           DateTime?
  wrongActive            Boolean   @default(false)
  wrongRecoveryRemaining Int       @default(0)
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  word                   Word      @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@id([userId, wordId])
  @@index([wordId])
}

model ResultState {
  userId      Int
  wordId      Int
  everCorrect Boolean     @default(false)
  everWrong   Boolean     @default(false)
  lastResult  LastResult?
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  word        Word        @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@id([userId, wordId])
  @@index([wordId])
}

model QuizProgress {
  userId               Int
  wordId               Int
  meaningCorrectStreak Int         @default(0)
  meaningNextReviewAt  DateTime?
  meaningLastResult    LastResult?
  wordCorrectStreak    Int         @default(0)
  wordNextReviewAt     DateTime?
  wordLastResult       LastResult?
  updatedAt            DateTime    @updatedAt
  user                 User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  word                 Word        @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@id([userId, wordId])
  @@index([wordId])
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  isAdmin  Boolean   @default(false)
  plan     UserPlan  @default(FREE)
  proUntil DateTime?
  dailyGoal Int      @default(30)

  wordbooks Wordbook[]
  downloads WordbookDownload[]
  ratings   WordbookRating[]
  progresses Progress[]
  resultStates ResultState[]
  quizProgresses QuizProgress[]
  wordbookStudyStates WordbookStudyState[]
  wordbookStudyItemStates WordbookStudyItemState[]
  blockedOwners BlockedOwner[] @relation("BlockedByUser")
  blockedByUsers BlockedOwner[] @relation("BlockedOwnerUser")
  submittedReports WordbookReport[] @relation("ReportByUser")
  reviewedReports WordbookReport[] @relation("ReportReviewedByUser")
}

model Wordbook {
  id          Int     @id @default(autoincrement())
  ownerId     Int
  title       String
  description String?
  fromLang    String  @default("en")
  toLang      String  @default("ko")
  isPublic    Boolean @default(false)
  hiddenByAdmin Boolean @default(false)

  downloadCount Int   @default(0)
  ratingAvg     Float @default(0)
  ratingCount   Int   @default(0)
  rankScore     Float @default(0)
  rankScoreUpdatedAt DateTime?
  contentVersion Int  @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner     User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  items     WordbookItem[]
  downloads WordbookDownload[]
  ratings   WordbookRating[]
  studyStates WordbookStudyState[]
  studyItemStates WordbookStudyItemState[]
  reports WordbookReport[]
  versionLogs WordbookVersionLog[]

  @@index([ownerId, createdAt])
  @@index([isPublic, ratingAvg, downloadCount, createdAt])
  @@index([isPublic, hiddenByAdmin, rankScore, createdAt])
}

model WordbookItem {
  id            Int      @id @default(autoincrement())
  wordbookId    Int
  term          String
  meaning       String
  pronunciation String?
  example       String?
  exampleMeaning String?
  position      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  wordbook Wordbook @relation(fields: [wordbookId], references: [id], onDelete: Cascade)
  studyItemStates WordbookStudyItemState[]

  @@index([wordbookId, position])
}

model WordbookDownload {
  id         Int      @id @default(autoincrement())
  userId     Int
  wordbookId Int
  createdAt  DateTime @default(now())
  downloadedVersion Int @default(1)
  snapshotItemCount Int @default(0)
  syncedAt DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wordbook Wordbook @relation(fields: [wordbookId], references: [id], onDelete: Cascade)

  @@unique([userId, wordbookId])
  @@index([wordbookId])
}

model WordbookVersionLog {
  id Int @id @default(autoincrement())
  wordbookId Int
  version Int
  addedCount Int @default(0)
  updatedCount Int @default(0)
  deletedCount Int @default(0)
  createdAt DateTime @default(now())

  wordbook Wordbook @relation(fields: [wordbookId], references: [id], onDelete: Cascade)

  @@index([wordbookId, version])
  @@index([wordbookId, createdAt])
}

model WordbookRating {
  id         Int      @id @default(autoincrement())
  userId     Int
  wordbookId Int
  rating     Int
  review     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wordbook Wordbook @relation(fields: [wordbookId], references: [id], onDelete: Cascade)

  @@unique([userId, wordbookId])
  @@index([wordbookId, rating])
  @@index([wordbookId, updatedAt])
}

model RateLimitBucket {
  id      String   @id
  count   Int
  resetAt DateTime
}

model WordbookStudyState {
  userId      Int
  wordbookId  Int
  studiedCount Int      @default(0)
  correctCount Int      @default(0)
  wrongCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wordbook  Wordbook @relation(fields: [wordbookId], references: [id], onDelete: Cascade)
  itemStates WordbookStudyItemState[]

  @@id([userId, wordbookId])
  @@index([wordbookId])
}

model WordbookStudyItemState {
  userId     Int
  wordbookId Int
  itemId     Int
  status     WordbookStudyStatus @default(NEW)
  streak     Int       @default(0)
  everCorrect Boolean  @default(false)
  everWrong   Boolean  @default(false)
  lastResult LastResult?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  wordbook Wordbook     @relation(fields: [wordbookId], references: [id], onDelete: Cascade)
  studyState WordbookStudyState @relation(fields: [userId, wordbookId], references: [userId, wordbookId], onDelete: Cascade)
  item     WordbookItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([userId, wordbookId, itemId])
  @@index([wordbookId, itemId])
  @@index([userId, itemId])
  @@index([userId, wordbookId, status])
  @@index([userId, wordbookId, everCorrect, everWrong])
  @@index([userId, lastResult, updatedAt])
}

model BlockedOwner {
  userId    Int
  ownerId   Int
  createdAt DateTime @default(now())

  user  User @relation("BlockedByUser", fields: [userId], references: [id], onDelete: Cascade)
  owner User @relation("BlockedOwnerUser", fields: [ownerId], references: [id], onDelete: Cascade)

  @@id([userId, ownerId])
  @@index([ownerId])
}

model WordbookReport {
  id            Int                @id @default(autoincrement())
  wordbookId    Int
  reporterId    Int
  reason        String
  detail        String?
  status        WordbookReportStatus @default(OPEN)
  reporterTrustScore Int           @default(0)
  moderatorNote String?
  reviewAction  String?
  previousStatus WordbookReportStatus?
  nextStatus    WordbookReportStatus?
  reviewerIpHash String?
  reviewedById  Int?
  reviewedAt    DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  wordbook   Wordbook @relation(fields: [wordbookId], references: [id], onDelete: Cascade)
  reporter   User     @relation("ReportByUser", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewedBy User?    @relation("ReportReviewedByUser", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([wordbookId, status, createdAt])
  @@index([reporterId, createdAt])
}

enum LastResult {
  CORRECT
  WRONG
}

enum UserPlan {
  FREE
  PRO
}

enum WordbookStudyStatus {
  NEW
  CORRECT
  WRONG
}

enum WordbookReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}
