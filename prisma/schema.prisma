generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Word {
  id          Int         @id @default(autoincrement())
  en          String      @unique
  ko          String
  createdAt   DateTime    @default(now())
  progress    Progress?
  resultState ResultState?
  quizProgress QuizProgress?
}

model Progress {
  wordId                 Int      @id
  correctStreak          Int      @default(0)
  nextReviewAt           DateTime?
  wrongActive            Boolean  @default(false)
  wrongRecoveryRemaining Int      @default(0)
  word                   Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)
}

model ResultState {
  wordId       Int        @id
  everCorrect  Boolean    @default(false)
  everWrong    Boolean    @default(false)
  lastResult   LastResult?
  updatedAt    DateTime   @updatedAt
  word         Word       @relation(fields: [wordId], references: [id], onDelete: Cascade)
}

model QuizProgress {
  wordId               Int        @id
  meaningCorrectStreak Int        @default(0)
  meaningNextReviewAt  DateTime?
  meaningLastResult    LastResult?
  wordCorrectStreak    Int        @default(0)
  wordNextReviewAt     DateTime?
  wordLastResult       LastResult?
  updatedAt            DateTime   @updatedAt
  word                 Word       @relation(fields: [wordId], references: [id], onDelete: Cascade)
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

enum LastResult {
  CORRECT
  WRONG
}
