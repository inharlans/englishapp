{
  "manifest_version": 3,
  "name": "Englishapp PDF Clipper",
  "version": "0.1.0",
  "description": "PDF에서 선택한 영어 단어를 Englishapp 단어장으로 보냅니다.",
  "minimum_chrome_version": "114",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Englishapp PDF Clipper"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
