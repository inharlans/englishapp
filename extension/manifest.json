{
  "manifest_version": 3,
  "name": "Englishapp PDF Clipper",
  "version": "0.1.0",
  "description": "Englishapp 페이지에서 선택한 영어 단어를 단어장으로 저장합니다.",
  "minimum_chrome_version": "114",
  "permissions": ["storage"],
  "action": {
    "default_title": "Englishapp PDF Clipper"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.oingapp.com/*",
        "https://oingapp.com/*",
        "https://127.0.0.1/*",
        "https://localhost/*",
        "http://127.0.0.1/*",
        "http://localhost/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page-bridge.js"],
      "matches": [
        "https://oingapp.com/*",
        "https://www.oingapp.com/*",
        "https://127.0.0.1/*",
        "https://localhost/*",
        "http://127.0.0.1/*",
        "http://localhost/*"
      ]
    }
  ]
}
