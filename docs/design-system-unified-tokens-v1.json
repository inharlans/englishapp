{
  "meta": {
    "name": "EnglishApp Unified Design Tokens",
    "version": "1.0.0",
    "date": "2026-03-05",
    "principles": [
      "calm",
      "focused",
      "minimal",
      "readable",
      "confidence"
    ]
  },
  "color": {
    "brand": {
      "primary": "#2F5FA8",
      "secondary": "#C48A3A"
    },
    "semantic": {
      "background": "#F6F8FB",
      "surface": "#FFFFFF",
      "text": "#142033",
      "textMuted": "#5A667A",
      "border": "#D6DEEA",
      "focus": "#2F5FA8",
      "success": "#2F7A5A",
      "warning": "#A9741F",
      "danger": "#C64646"
    }
  },
  "type": {
    "display": {
      "fontSize": 32,
      "fontWeight": 700,
      "lineHeight": 40
    },
    "title": {
      "fontSize": 24,
      "fontWeight": 700,
      "lineHeight": 32
    },
    "body": {
      "fontSize": 16,
      "fontWeight": 400,
      "lineHeight": 24
    },
    "caption": {
      "fontSize": 13,
      "fontWeight": 500,
      "lineHeight": 18
    }
  },
  "spacing": {
    "xs": 4,
    "sm": 8,
    "md": 12,
    "lg": 16,
    "xl": 24,
    "xxl": 32
  },
  "radius": {
    "sm": 10,
    "md": 14,
    "lg": 20,
    "pill": 999
  },
  "shadow": {
    "sm": "0 1px 2px rgba(20, 32, 51, 0.08)",
    "md": "0 8px 20px rgba(20, 32, 51, 0.10)"
  },
  "motion": {
    "duration": {
      "fast": 120,
      "base": 180,
      "slow": 240
    },
    "easing": {
      "standard": "cubic-bezier(0.2, 0, 0, 1)"
    }
  }
}
