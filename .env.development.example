DATABASE_URL="postgresql://postgres:postgres@localhost:5432/englishapp?schema=public"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Core auth / debug
AUTH_SECRET="dev-secret-change-me"
CRON_SECRET="dev-cron-secret-change-me"
LOCAL_AUTH_BYPASS="true"
SEED_LOCAL_DEBUG="0"
ALLOW_NONLOCAL_DEBUG_SEED="0"
LOCAL_DEBUG_EMAIL="debug@local.oingapp"
LOCAL_DEBUG_PASSWORD="debug1234!"

# Clipper enrichment (Gemini)
GEMINI_API_KEY=""
CLIPPER_LLM_PROVIDER="gemini"
CLIPPER_LLM_MODEL="gemini-2.5-flash-lite"
CLIPPER_ENRICH_BATCH_SIZE="10"
CLIPPER_ENRICH_MAX_WAIT_SECONDS="60"
CLIPPER_ENRICH_MAX_ATTEMPTS="3"

# OAuth providers (optional in local)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""
NAVER_REDIRECT_URI="http://localhost:3000/api/auth/naver/callback"
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""
KAKAO_REDIRECT_URI="http://localhost:3000/api/auth/kakao/callback"

# Internal test route (non-production only)
E2E_SECRET="dev-e2e-secret-change-me"
PREVIEW_ACCESS_TOKEN="dev-preview-access-token"
INTERNAL_E2E_ALLOWED_IPS=""
E2E_TEST_EMAIL="e2e-clipped@example.com"

# Optional fallback translation
GOOGLE_TRANSLATE_API_KEY=""

# Payments (optional for local functional testing)
PORTONE_API_SECRET=""
PORTONE_WEBHOOK_SECRET=""
PORTONE_STORE_ID=""
PORTONE_CHANNEL_KEY=""
PORTONE_PRICE_MONTHLY_KRW="2900"
PORTONE_PRICE_YEARLY_KRW="29000"

# Optional rate-limit backend
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
