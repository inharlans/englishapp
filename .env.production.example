DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# Core auth
AUTH_SECRET="replace-with-strong-random-secret"
CRON_SECRET="replace-with-strong-random-secret"

# Clipper enrichment (Gemini)
GEMINI_API_KEY=""
CLIPPER_LLM_PROVIDER="gemini"
CLIPPER_LLM_MODEL="gemini-2.5-flash-lite"
CLIPPER_ENRICH_BATCH_SIZE="10"
CLIPPER_ENRICH_MAX_WAIT_SECONDS="60"
CLIPPER_ENRICH_MAX_ATTEMPTS="3"

# OAuth providers (set only providers you use)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI=""
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""
NAVER_REDIRECT_URI=""
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""
KAKAO_REDIRECT_URI=""

# Payments (PortOne)
PORTONE_API_SECRET=""
PORTONE_WEBHOOK_SECRET=""
PORTONE_STORE_ID=""
PORTONE_CHANNEL_KEY=""
PORTONE_PRICE_MONTHLY_KRW="2900"
PORTONE_PRICE_YEARLY_KRW="29000"

# Optional hardening / ops
INTERNAL_CRON_ALLOWED_IPS=""
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
PREVIEW_ACCESS_TOKEN=""

# Optional fallback translation
GOOGLE_TRANSLATE_API_KEY=""
