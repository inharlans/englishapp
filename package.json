{
  "name": "englishapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint app components lib tests middleware.ts next.config.ts",
    "typecheck": "next typegen && tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:e2e": "node tests/e2e/http-smoke.mjs",
    "test:e2e:ui": "node tests/e2e/ui-flow.mjs",
    "test:e2e:local": "powershell -ExecutionPolicy Bypass -File scripts/dev/dev-and-test.ps1 -Suite all",
    "test:e2e:local:smoke": "powershell -ExecutionPolicy Bypass -File scripts/dev/dev-and-test.ps1 -Suite smoke",
    "test:e2e:local:ui": "powershell -ExecutionPolicy Bypass -File scripts/dev/dev-and-test.ps1 -Suite ui",
    "mcp:cycle": "node scripts/ops/mcp-cycle.js",
    "ops:readiness": "node scripts/ops/ops-readiness.js",
    "completion:report": "node scripts/ops/write-completion-report.js",
    "hooks:validate": "node scripts/ops/validate-hook-chains.js && node scripts/ops/validate-text-encoding.js",
    "encoding:validate": "node scripts/ops/validate-text-encoding.js",
    "env:set": "node scripts/dev/set-env-var.mjs",
    "auto:loop": "powershell -ExecutionPolicy Bypass -File scripts/ops/auto-loop-runner.ps1",
    "test:watch": "vitest",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "node prisma/seed.js",
    "wordbooks:cleanup-broken-descriptions": "node scripts/data/cleanup-broken-descriptions.mjs",
    "wordbooks:report-meaning-quality": "node scripts/data/report-meaning-quality.mjs",
    "wordbooks:cleanse-meaning-quality": "node scripts/data/cleanse-meaning-quality.mjs",
    "wordbooks:cleanse-meaning-quality:apply": "node scripts/data/cleanse-meaning-quality.mjs --apply",
    "wordbooks:recompute-rank": "node scripts/data/recompute-wordbook-rank.mjs",
    "start:railway": "prisma generate && prisma migrate deploy && next start -p ${PORT:-3000}",
    "start:railway:seed": "prisma generate && prisma migrate deploy && node prisma/seed.js && next start -p ${PORT:-3000}"
  },
  "dependencies": {
    "@next/eslint-plugin-next": "^15.5.12",
    "@portone/browser-sdk": "^0.1.3",
    "@portone/server-sdk": "^0.19.0",
    "@prisma/client": "^6.4.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.2",
    "bcryptjs": "^2.4.3",
    "jose": "^5.9.6",
    "next": "^15.5.12",
    "prisma": "^6.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.5.12",
    "playwright": "^1.58.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18",
    "xlsx": "^0.18.5"
  }
}
